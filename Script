-- ✨ ESP NAME PEQUENO E BONITO - NÃO SOME MAIS ✨
-- =============================================
local Billboards = {}
local Tempo = 0

spawn(function()
    while wait() do
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= player then
                local character = plr.Character
                if character then
                    local HumanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                    if HumanoidRootPart and not Billboards[plr.Name] then
                        
                        local Billboard = Instance.new("BillboardGui")
                        Billboard.Size = UDim2.new(0, 70, 0, 20)
                        Billboard.StudsOffset = Vector3.new(0, 2.8, 0)
                        Billboard.AlwaysOnTop = true
                        Billboard.Parent = HumanoidRootPart
                        
                        local Nome = Instance.new("TextLabel", Billboard)
                        Nome.Size = UDim2.new(1, 0, 1, 0)
                        Nome.BackgroundTransparency = 1
                        Nome.Text = plr.Name
                        Nome.TextScaled = true
                        Nome.Font = Enum.Font.GothamSemibold
                        Nome.TextSize = 14
                        Nome.TextColor3 = Color3.new(1,1,1)
                        
                        local Borda = Instance.new("UIStroke", Nome)
                        Borda.Color = Color3.new(0,0,0)
                        Borda.Thickness = 1.5
                        
                        Billboards[plr.Name] = Nome
                    end
                end
            end
        end
    end
end)

RunService.RenderStepped:Connect(function(dt)
    Tempo = Tempo + dt
    local Cor = Color3.fromHSV(Tempo % 1, 1, 1)
    for _, NomeTxt in pairs(Billboards) do
        if NomeTxt then NomeTxt.TextColor3 = Cor end
    end
end)

